{
  "manifest_version": 3,
  "name": "trace-pilot-chrome",
  "version": "1.1.0",
  "description": "trace-pilot-chrome",

  "permissions": [
    "offscreen",
    "clipboardWrite",
    "scripting",
    "contextMenus",
    "nativeMessaging",
    "tabs",
    "pageCapture"
  ],

  "host_permissions":["<all_urls>"],

  "background": {
    "service_worker": "dist/background/background.js",
    "type": "module"
  },

  "action":{
    "default_icon": {
      "16": "Assets/trace-pilot_icon2.png",
      "32": "Assets/trace-pilot_icon2.png",
      "48": "Assets/trace-pilot_icon2.png",
      "128": "Assets/trace-pilot_icon2.png"
    }
  },

  "icons": {
    "16": "Assets/trace-pilot_icon2.png",
    "32": "Assets/trace-pilot_icon2.png",
    "48": "Assets/trace-pilot_icon2.png",
    "128": "Assets/trace-pilot_icon2.png"
  },


  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["dist/content/content.js"]
    }
  ]
}
